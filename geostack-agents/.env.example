# Copy to .env (gitignored) and fill in.
# Sourced by each agent's startup.sh and read by src/mastra/model.ts.

# OpenRouter API key — agents call OpenRouter directly (no Coral LLM proxy).
# Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# Optional. Exa hosted MCP (https://mcp.exa.ai/mcp) works keyless on the free
# tier; supply only if you hit rate limits. Used by search-agent.
EXA_API_KEY=
