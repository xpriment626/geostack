# Copy to .env and fill in.
# Read by the Svelte app via Vite (envDir is set to this directory).
# Both must use the VITE_ prefix so Vite exposes them to client code via
# import.meta.env. At session-create time the Wizard will forward these as
# Coral agent options for the search-agent and thumbnail-agent.

# Replicate API token — used by thumbnail-agent to call openai/gpt-image-2
# via Replicate's MCP server. Create one at
# https://replicate.com/account/api-tokens
VITE_REPLICATE_API_TOKEN=

# Exa API key — optional. Exa's hosted MCP at https://mcp.exa.ai/mcp works
# without a key on the free tier; supply one only if you hit rate limits or
# want higher quotas. Get one at https://dashboard.exa.ai/api-keys
VITE_EXA_API_KEY=
