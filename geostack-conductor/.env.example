# Copy to .env (gitignored) and fill in.
# The conductor reads these at startup.

# --- Turso archive (runs / agent_turns / sessions) -------------------------
# Create a DB in your Turso cloud account, then paste its URL + an auth token.
#   turso db create geostack
#   turso db show geostack --url           -> TURSO_DATABASE_URL
#   turso db tokens create geostack        -> TURSO_AUTH_TOKEN
# If left blank, the conductor still runs — the archive layer just no-ops.
TURSO_DATABASE_URL=libsql://geostack-<your-org>.turso.io
TURSO_AUTH_TOKEN=

# --- Coral connection (optional; these are the defaults) -------------------
# CORAL_SERVER_URL=http://localhost:5555
# CORAL_TOKEN=local

# --- Conductor server (optional) -------------------------------------------
# PORT=8787

# --- Run timeouts in ms (optional; sized for slow reasoning models) --------
# GEOSTACK_READY_TIMEOUT_MS=90000
# GEOSTACK_RESEARCH_TIMEOUT_MS=360000
# GEOSTACK_SYNTHESIS_TIMEOUT_MS=900000
